{
  "swagger": "2.0",
  "info": {
    "title": "HelpDesk API",
    "description": "HelpDesk Service exposes two core domains:\n\n1. **Ratings** — Users can rate any entity (product, order, service, etc.) identified by a `type` and `entity_id`. Each rating captures the user, a numeric score (validated against the configured max scale, e.g. 1–5 or 1–10), and an optional free-text comment. Admins or entity owners can reply to any rating to acknowledge feedback (especially poor ratings).\n\n2. **Issues \u0026 Conversations** — Users can report issues against any entity. Admins and users exchange replies in a threaded conversation attached to the issue until it is marked resolved or closed. Issue status transitions: open → in_progress → resolved → closed.",
    "version": "v1.0.0"
  },
  "tags": [
    {
      "name": "Ping",
      "description": "Health check endpoints"
    },
    {
      "name": "Ratings",
      "description": "Submit, retrieve, update, and delete ratings for any entity. A rating belongs to a user and targets a specific entity identified by type + entity_id. The allowed score range is controlled by the Ratings.MaxScale configuration value."
    },
    {
      "name": "RatingReplies",
      "description": "Responses to ratings. Admins or entity owners can reply to a rating to acknowledge feedback — particularly useful for poor ratings. Each rating can have multiple replies, returned in chronological order."
    },
    {
      "name": "Issues",
      "description": "Report and manage helpdesk issues for any entity. Each issue has a title, description, and a lifecycle status (open, in_progress, resolved, closed)."
    },
    {
      "name": "Replies",
      "description": "Threaded conversation on an issue. Both users and admins can post replies. Replies are returned in chronological order. The conversation continues across status changes until the issue is closed."
    },
    {
      "name": "BaseService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
